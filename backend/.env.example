NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/financial_dashboard?schema=public
JWT_ACCESS_SECRET=replace_with_a_secure_access_secret
JWT_REFRESH_SECRET=replace_with_a_secure_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true
MONITORING_API_KEY=replace_with_a_long_random_monitoring_key
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-7-sonnet-latest
AI_REQUEST_TIMEOUT_MS=20000
AI_MAX_TOKENS=1400
AI_TEMPERATURE=0.2
AI_INSIGHT_CACHE_TTL_SECONDS=900
STOCK_CACHE_TTL_SECONDS=60
REDIS_REST_URL=
REDIS_REST_TOKEN=
